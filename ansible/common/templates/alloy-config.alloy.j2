// Journald log shipping to Loki
loki.relabel "journal" {
  forward_to = []

  rule {
    source_labels = ["__journal__systemd_unit"]
    target_label  = "unit"
  }

  rule {
    source_labels = ["__journal__transport"]
    target_label  = "transport"
  }
}

loki.source.journal "read" {
  forward_to    = [loki.write.loki.receiver]
  relabel_rules = loki.relabel.journal.rules
  labels        = { source = "journald", host = "{{ monitoring_hostname }}" }
}

loki.write "loki" {
  endpoint {
    url = "{{ loki_push_url }}"
    // doc2 (Loki host) auto-reboots nightly for ~10-15 min. Default
    // max_backoff_period=5m exhausted retries at ~9 min and dropped
    // a batch on 2026-05-21. Bump so the in-memory queue rides
    // normal maintenance windows; WAL covers anything longer.
    max_backoff_period = "10m"
    // Force HTTP/1.1. Non-rebooting pushers (prom, tower) hold ONE
    // long-lived connection; over HTTP/2 it gets coalesced across the
    // shared nginx vhost on doc2, and when doc2 reloads/reboots nginx
    // the aged connection starts returning 421 Misdirected Request
    // forever — alloy never redials, so log shipping silently stops
    // until a manual restart (2026-06-18 triage). HTTP/1.1 can't
    // coalesce, so the 421 class can't occur. NixOS hosts dodged it
    // only because they reboot nightly (fresh connection each day).
    enable_http2 = false
  }

  // Persist queued batches to /var/lib/alloy/data so we do not lose
  // logs when Loki is briefly down OR when alloy itself restarts.
  // WAL is off by default in alloy; prometheus.remote_write to Mimir
  // already has its own on-disk WAL, so this closes the symmetric
  // Loki-side gap. Mirrors modules/nixos/services/loki.nix.
  wal {
    enabled         = true
    max_segment_age = "2h"
  }
}

// Scrape node-exporter metrics
prometheus.scrape "node" {
  targets = [{
    __address__ = "localhost:9100",
    instance    = "{{ monitoring_hostname }}",
  }]
  forward_to      = [prometheus.remote_write.mimir.receiver]
  scrape_interval = "60s"
  job_name        = "node"
}

// Push metrics to Mimir
prometheus.remote_write "mimir" {
  endpoint {
    url = "{{ mimir_push_url }}"
    // Same 421/HTTP-2-coalescing fix as loki.write above — metrics take
    // the same shared nginx vhost on doc2. See the loki.write comment.
    enable_http2 = false
  }
  external_labels = {
    host = "{{ monitoring_hostname }}",
  }
}
