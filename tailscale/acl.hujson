// Tailscale ACL — repo-authoritative tailnet policy (issue #239).
//
// Model: five role tags on a default-DENY tailnet, authored in the modern
// `grants` syntax (classic `acls` are frozen upstream). Applied self-hosted from
// doc1 (the bastion) via gitops-pusher (modules/nixos/services/tailscale/acl-apply.nix)
// using a `policy_file`-scoped OAuth client held in sops on doc1 only.
//
//   tag:server  full mesh; the fleet's service VMs + pfSense + tower + legacy VMs
//   tag:client  personal devices; client↔client open, a SHORT allowlist into servers
//   tag:share   inbound-443 share sidecars (own devices + inter-tailnet shares)
//   tag:edge    remote/isolated nodes; no implicit fleet access, enumerated egress only
//   tag:cullen  the Cullen-site laptop (laptop-btibh4ie/wsl) — strictest: a minimal
//               management plane out + deploy/dev SSH + Syncthing in; nothing else
//
// Plan: docs/plans/2026-06-07-002-feat-tailscale-acl-least-privilege-plan.md
// Audit (flip-readiness, complete grant set): docs/wiki/infrastructure/tailscale-acl-flip-audit.md
// Wiki: docs/wiki/infrastructure/tailscale-acl.md (U8)
//
// ============================ STAGING (READ ME) =============================
// This file is in its STAGED form: it carries a `*:*` allow-all grant (clearly
// marked below) so applying it is NON-DESTRUCTIVE — nothing is restricted yet.
// The `tests` block therefore holds ACCEPT-only assertions (allow-all makes every
// DENY assertion false). The DENY assertions that prove real grant correctness are
// parked, commented, below the tests block. THE FLIP is a single edit: delete the
// allow-all grant AND swap in the deny tests, then re-apply from the home LAN.
// ===========================================================================
{
  // ----------------------------------------------------------------- tagOwners
  // Who may apply each tag. autogroup:admin = the tailnet admins (abl030).
  "tagOwners": {
    "tag:server": ["autogroup:admin"],
    "tag:client": ["autogroup:admin"],
    "tag:share":  ["autogroup:admin"],
    "tag:edge":   ["autogroup:admin"],
    "tag:cullen": ["autogroup:admin"],
  },

  // --------------------------------------------------------------------- hosts
  // Named IPs for precise per-node grants/tests. Tailnet IPs are stable per node;
  // re-pin only if a node is deleted + re-created (fails closed if stale).
  "hosts": {
    "doc1":          "100.89.160.60",  // the bastion — the only node that deploys cullen
    "pfsense":       "100.123.61.111", // recursive DNS resolver for the whole fleet
    "framework":     "100.78.17.73",   // dev workstation; reaches cullen for Cullen-side work
    "cullen":        "100.75.246.114", // laptop-btibh4ie (Windows) — wsl SSH jump + Cullen route
    "homeassistant": "100.106.165.120", // the ONLY node allowed to reach the Cullen inverters
    "kerrynas":      "100.100.237.21",  // mum's Synology — offsite kopia/NFS backup target
    "hermes":        "100.78.254.6",   // locked-down agent VM (keyless re: the fleet, see grants)
  },

  // -------------------------------------------------------------------- grants
  "grants": [
    // === tag:server — full mesh ============================================
    // doc1, doc2, igpu, caddy, downloader, pfsense, tower. Server↔server is open
    // (intra-fleet microsegmentation is #232's job, at container granularity).
    // Covers server→pfsense:53 (DNS), telemetry push (→doc2:443), Tempo OTLP, etc.
    { "src": ["tag:server"], "dst": ["tag:server"], "ip": ["*"] },

    // server → kerrynas: offsite backup only (doc2 kopia-mum NFS mount, by node
    // IP via MagicDNS). NFS: tcp:2049 (v4) + 111 (rpcbind, if v3 negotiated).
    // TODO: confirm v4-only and narrow to ["tcp:2049"]. kerrynas is tag:edge.
    { "src": ["tag:server"], "dst": ["kerrynas"], "ip": ["tcp:2049", "tcp:111", "udp:111"] },

    // === tag:client — personal devices ====================================
    // framework, epimetheus, s-a55 (phone). (laptop-btibh4ie is tag:cullen, below.)
    // Short allowlist into servers: SSH + 443 (every web service behind nginx,
    // incl. Loki/Mimir telemetry push to loki.ablz.au/mimir.ablz.au).
    { "src": ["tag:client"], "dst": ["tag:server"], "ip": ["tcp:22", "tcp:443"] },

    // DNS — the #1 lockout risk. tailscaled forwards to pfSense over the tailnet;
    // TCP/53 is load-bearing in this environment (not UDP-only). Both protos.
    { "src": ["tag:client"], "dst": ["pfsense"], "ip": ["tcp:53", "udp:53"] },

    // Roaming clients reach the home LAN (via tower) and dad's LAN (via rpi).
    { "src": ["tag:client"], "dst": ["192.168.0.0/23"], "ip": ["*"] },
    { "src": ["tag:client"], "dst": ["192.168.2.0/24"], "ip": ["*"] },

    // Clients may use an approved exit node (tower) for full internet egress.
    { "src": ["tag:client"], "dst": ["autogroup:internet"], "ip": ["*"] },

    // client↔client: personal devices fully trust each other. Covers Sunshine
    // (Moonlight), GNOME RDP, WayVNC, Syncthing-among-clients, etc. The real
    // restriction is client→SERVER (the short allowlist above); your own gadgets
    // talking to each other is low-risk. NOTE: tag:cullen is deliberately NOT a
    // client and so is EXCLUDED from this blanket.
    { "src": ["tag:client"], "dst": ["tag:client"], "ip": ["*"] },

    // === tag:share — share sidecars (inbound 443) =========================
    // overseer, jellyfin-1, audiobookshelf, hermes-ui. Reached over the tailnet
    // (FQDN→100.x) by BOTH the owner's own devices AND external users via
    // inter-tailnet node-sharing (e.g. overseer shared to ali@). They get NO
    // egress into the fleet (share→fleet stays denied — see the deny tests).
    { "src": ["tag:client"], "dst": ["tag:share"], "ip": ["tcp:443"] },
    // External shared-in users (accounts we've shared nodes with) reach whatever
    // is shared to them on 443. The node-share mechanism limits WHO sees WHICH
    // node (ali only sees overseer); this grant just lets the 443 through. New
    // inter-tailnet shares "just work" as long as the target is tag:share.
    { "src": ["autogroup:shared"], "dst": ["tag:share"], "ip": ["tcp:443"] },

    // === Syncthing mesh ====================================================
    // Participants: epi, framework (client), doc1, igpu (server), cullen. It's a
    // mesh; either peer may initiate. One symmetric grant on the syncthing ports
    // (tcp/udp 22000 data, udp 21027 discovery). Non-participants (doc2, caddy,
    // phone, …) don't listen on these, so the tag-broad dst is harmless. This is
    // cullen's ONLY data path into the fleet (NFS deliberately omitted — see #4).
    { "src": ["tag:client", "tag:server", "tag:cullen"], "dst": ["tag:client", "tag:server", "tag:cullen"], "ip": ["tcp:22000", "udp:22000", "udp:21027"] },

    // === tag:cullen — the Cullen-site laptop (laptop-btibh4ie / wsl) ========
    // Strictest tag. A compromise here must not pivot into the fleet, and the
    // fleet must not roam the Cullen LAN. wsl is still a MANAGED NixOS host, so it
    // gets a MINIMAL outbound management plane (not zero, or it can't auto-update).
    //   IN : deploy + dev SSH from doc1 (bastion) and framework only.
    //   OUT: DNS to pfSense; doc1/doc2 web ports for fleet-update (Forgejo +
    //        nix-cache), Loki/Mimir push, and Gotify (8050) — via tower's route.
    //   + Syncthing (mesh grant above). NOT client↔client, NOT the broad fleet,
    //     NOT the exit node, NO broad NFS (transport is moving to Syncthing, #4).
    // The Cullen LAN route stays inverters-only for the fleet (HA grant below).
    { "src": ["doc1", "framework"], "dst": ["tag:cullen"], "ip": ["tcp:22"] },
    { "src": ["tag:cullen"], "dst": ["pfsense"], "ip": ["tcp:53", "udp:53"] },
    { "src": ["tag:cullen"], "dst": ["192.168.1.0/24"], "ip": ["tcp:443", "tcp:8050"] },

    // === tag:edge — remote / isolated nodes ================================
    // homeassistant, raspberrypi (dad's), kerrynas (mum's), hermes.
    // No implicit fleet access; egress enumerated per-node; inbound only what is
    // explicitly granted (e.g. server→kerrynas NFS above).
    //
    // HA → the two Cullen inverters ONLY (solar). The 192.168.100.0/24 route is
    // advertised (so the /32s are routable) but access is pinned to these /32s.
    // Port CONFIRMED tcp:443 (2026-06-21): `pysmaplus` in ennexOS mode talks HTTPS
    // to https://<ip>/api/v1/... — verified by source + a live probe of both IPs.
    // NOT Speedwire (udp:9522) / Modbus (tcp:502). .139 = Bank A + Bank B cluster
    // gateway; .133 = Warehouse. (Bank B is a SD2P sub-device behind .139, no own IP.)
    { "src": ["homeassistant"], "dst": ["192.168.100.139/32", "192.168.100.133/32"], "ip": ["tcp:443"] },

    // === hermes — locked-down agent VM ====================================
    // Keyless re: the fleet, the blast-radius boundary for LLM-generated code.
    // tag:edge, so NO server mesh; exactly two tailnet paths:
    //   1. inbound :22 from servers — doc1 bastion `fleet-deploy hermes`.
    //   2. outbound DNS to pfSense.
    // Dashboard is the SEPARATE hermes-ui share sidecar (tag:share). Observability
    // (loki/prometheus/gotify with doc2) runs over the prom LAN, not the tailnet.
    { "src": ["tag:server"], "dst": ["hermes"], "ip": ["tcp:22"] },
    { "src": ["hermes"], "dst": ["pfsense"], "ip": ["tcp:53", "udp:53"] },

    // ====================== STAGED ALLOW-ALL — REMOVE AT FLIP ===============
    // Makes this policy non-destructive. DELETE this single grant (and swap in the
    // deny tests below) to flip the tailnet to default-deny.
    { "src": ["*"], "dst": ["*"], "ip": ["*"] },
    // ========================================================================
  ],

  // ----------------------------------------------------------------------- ssh
  // Tailscale SSH — PRESERVE the default: members reach their OWN devices in check
  // mode. This governs `tailscale ssh`, used for user-owned non-fleet nodes (e.g.
  // tower). SEPARATE from OpenSSH:22 (the fleet's SSH, on the tcp:22 grants above).
  // IMPORTANT: action "check" requires USERS/groups in `src` — tags are INVALID
  // here, so do NOT "tighten" this to tags (it disables `tailscale ssh` fleet-wide).
  "ssh": [
    {
      "action": "check",
      "src":    ["autogroup:member"],
      "dst":    ["autogroup:self"],
      "users":  ["autogroup:nonroot", "root"],
    },
  ],

  // -------------------------------------------------------------- autoApprovers
  // Pre-approve advertised subnet routes + exit nodes by tag (NOT retroactive).
  "autoApprovers": {
    "routes": {
      "192.168.0.0/23":   ["tag:server"], // tower → home LAN
      "192.168.100.0/24": ["tag:cullen"], // laptop-btibh4ie → Cullen site
      "192.168.2.0/24":   ["tag:edge"],   // raspberrypi → dad's LAN
      "192.168.4.0/23":   ["tag:edge"],   // kerrynas → mum's LAN
    },
    // Tag-server-wide: only tower advertises exit today. (rpi also offers exit but
    // is tag:edge, so it is NOT auto-approved — intentional; the fleet uses tower.)
    "exitNode": ["tag:server"],
  },

  // --------------------------------------------------------------------- tests
  // Static accept assertions (allow-all present → accept-only; denies parked below).
  "tests": [
    // DNS preserved (the #1 lockout risk), both protocols.
    { "src": "tag:client", "proto": "tcp", "accept": ["pfsense:53"] },
    { "src": "tag:client", "proto": "udp", "accept": ["pfsense:53"] },
    // client → server allowlist; client↔client; client → share.
    { "src": "tag:client", "proto": "tcp", "accept": ["tag:server:22", "tag:server:443", "tag:client:22000", "tag:share:443"] },
    // server mesh sanity.
    { "src": "tag:server", "proto": "tcp", "accept": ["tag:server:22", "pfsense:53"] },
    // cullen: deploy/dev SSH in; DNS + management + syncthing out.
    { "src": "doc1", "proto": "tcp", "accept": ["cullen:22"] },
    { "src": "framework", "proto": "tcp", "accept": ["cullen:22"] },
    { "src": "cullen", "proto": "tcp", "accept": ["pfsense:53", "tag:server:22000"] },
    { "src": "cullen", "proto": "udp", "accept": ["pfsense:53"] },
    // hermes → pfSense DNS; server → hermes:22.
    { "src": "hermes", "proto": "tcp", "accept": ["pfsense:53"] },
    // HA → inverter reachable.
    { "src": "homeassistant", "proto": "tcp", "accept": ["192.168.100.139:443"] },
  ],

  // ===================== FLIP DENY TESTS — SWAP IN AT FLIP ==================
  // When you delete the allow-all grant, REPLACE the accept-only `tests` above
  // with one that also contains these denies (the real grant-correctness gate):
  //
  //   { "src": "tag:client", "proto": "tcp", "deny": ["tag:server:8080"] },        // client → non-allowlisted server port
  //   { "src": "tag:edge",   "proto": "tcp", "deny": ["tag:server:443"] },         // edge → fleet
  //   { "src": "homeassistant", "proto": "tcp", "deny": ["192.168.100.140:443"] }, // HA → adjacent (non-inverter) Cullen IP
  //   { "src": "tag:share",  "proto": "tcp", "deny": ["tag:server:443"] },         // share → fleet
  //   { "src": "hermes",     "proto": "tcp", "deny": ["tag:server:443"] },         // hermes → fleet mesh
  //   { "src": "s-a55",      "proto": "tcp", "deny": ["cullen:22", "cullen:443"] },// non-deployer client → cullen
  //   { "src": "cullen",     "proto": "tcp", "deny": ["tag:server:443", "tag:client:443"] }, // cullen → fleet (only mgmt/syncthing allowed)
  // ========================================================================
}
