{
  "annotations": {"list": []},
  "description": "Per-interface totals (WAN + AirVPN tunnels) and per-client LAN breakdown. VPN-routed LAN hosts are tagged via a regex substituted at Nix build time from homelab.loki.ntopngExporter.vpnClientIPs. See docs/wiki/services/lgtm-stack.md.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
      "id": 10,
      "panels": [],
      "title": "Interface totals (bps)",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "description": "Current bps on pfSense WAN (igc0). Includes direct-routed traffic AND WireGuard-encapsulated traffic destined for AirVPN — everything leaving your network passes here.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "decimals": 1,
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 100000000},
              {"color": "orange", "value": 500000000}
            ]
          },
          "unit": "bps"
        },
        "overrides": []
      },
      "gridPos": {"h": 5, "w": 8, "x": 0, "y": 1},
      "id": 1,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "showPercentChange": false,
        "textMode": "auto",
        "wideLayout": true
      },
      "pluginVersion": "12.4.2",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "Prometheus"},
          "editorMode": "code",
          "expr": "8 * sum(rate(ntopng_interface_bytes_rcvd{ifname=\"WAN\"}[$__rate_interval]) + rate(ntopng_interface_bytes_sent{ifname=\"WAN\"}[$__rate_interval]))",
          "legendFormat": "WAN",
          "range": false,
          "instant": true,
          "refId": "A"
        }
      ],
      "title": "WAN",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "description": "Current bps on the AirVPN New Zealand WireGuard tunnel (tun_wg2). This is the plaintext traffic of LAN clients that pfSense policy-routes through AirVPN — NOT the WG-encrypted bytes on WAN.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "decimals": 1,
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 50000000},
              {"color": "orange", "value": 200000000}
            ]
          },
          "unit": "bps"
        },
        "overrides": []
      },
      "gridPos": {"h": 5, "w": 8, "x": 8, "y": 1},
      "id": 2,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "showPercentChange": false,
        "textMode": "auto",
        "wideLayout": true
      },
      "pluginVersion": "12.4.2",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "Prometheus"},
          "editorMode": "code",
          "expr": "8 * sum(rate(ntopng_interface_bytes_rcvd{ifname=\"AirVPN NZ\"}[$__rate_interval]) + rate(ntopng_interface_bytes_sent{ifname=\"AirVPN NZ\"}[$__rate_interval]))",
          "legendFormat": "AirVPN NZ",
          "range": false,
          "instant": true,
          "refId": "A"
        }
      ],
      "title": "AirVPN NZ",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "description": "Current bps on the AirVPN Singapore WireGuard tunnel (tun_wg0). Usually idle unless you explicitly hit the SG gateway.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "decimals": 1,
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 50000000},
              {"color": "orange", "value": 200000000}
            ]
          },
          "unit": "bps"
        },
        "overrides": []
      },
      "gridPos": {"h": 5, "w": 8, "x": 16, "y": 1},
      "id": 3,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "showPercentChange": false,
        "textMode": "auto",
        "wideLayout": true
      },
      "pluginVersion": "12.4.2",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "Prometheus"},
          "editorMode": "code",
          "expr": "8 * sum(rate(ntopng_interface_bytes_rcvd{ifname=\"AirVPN SG\"}[$__rate_interval]) + rate(ntopng_interface_bytes_sent{ifname=\"AirVPN SG\"}[$__rate_interval]))",
          "legendFormat": "AirVPN SG",
          "range": false,
          "instant": true,
          "refId": "A"
        }
      ],
      "title": "AirVPN SG",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "description": "Bytes-per-second over time on WAN and both AirVPN tunnels. Useful to spot VPN vs direct-internet bandwidth splits.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "line",
            "fillOpacity": 15,
            "gradientMode": "none",
            "hideFrom": {"legend": false, "tooltip": false, "viz": false},
            "insertNulls": false,
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "pointSize": 5,
            "scaleDistribution": {"type": "linear"},
            "showPoints": "never",
            "spanNulls": false,
            "stacking": {"group": "A", "mode": "none"},
            "thresholdsStyle": {"mode": "off"}
          },
          "mappings": [],
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}]},
          "unit": "bps"
        },
        "overrides": []
      },
      "gridPos": {"h": 9, "w": 24, "x": 0, "y": 6},
      "id": 4,
      "options": {
        "legend": {"calcs": ["mean", "max", "last"], "displayMode": "table", "placement": "bottom", "showLegend": true},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "pluginVersion": "12.4.2",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "Prometheus"},
          "editorMode": "code",
          "expr": "8 * sum by (ifname) (rate(ntopng_interface_bytes_rcvd{ifname=~\"WAN|AirVPN NZ|AirVPN SG\"}[$__rate_interval]) + rate(ntopng_interface_bytes_sent{ifname=~\"WAN|AirVPN NZ|AirVPN SG\"}[$__rate_interval]))",
          "legendFormat": "{{ifname}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Interface throughput (Rx + Tx)",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 15},
      "id": 11,
      "panels": [],
      "title": "LAN clients — who's doing the talking",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "description": "Per-client LAN bandwidth. 'Route' shows whether pfSense policy-routes the IP through AirVPN (VPN) or straight to WAN (Direct). Sync'd at Nix build time from homelab.loki.ntopngExporter.vpnClientIPs — if this ever drifts from pfSense's MV_VPN_IPS alias, update the Nix option and redeploy.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "custom": {
            "align": "auto",
            "cellOptions": {"type": "auto"},
            "inspect": false
          },
          "mappings": [],
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}]},
          "unit": "bps"
        },
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "Route"},
            "properties": [
              {"id": "custom.cellOptions", "value": {"mode": "basic", "type": "color-background"}},
              {"id": "custom.width", "value": 100},
              {"id": "mappings", "value": [
                {"type": "value", "options": {"VPN": {"color": "purple", "index": 0, "text": "VPN"}}},
                {"type": "value", "options": {"Direct": {"color": "green", "index": 1, "text": "Direct"}}}
              ]},
              {"id": "unit", "value": "none"}
            ]
          },
          {
            "matcher": {"id": "byName", "options": "IP"},
            "properties": [{"id": "custom.width", "value": 160}]
          },
          {
            "matcher": {"id": "byName", "options": "Name"},
            "properties": [{"id": "custom.width", "value": 320}]
          }
        ]
      },
      "gridPos": {"h": 12, "w": 24, "x": 0, "y": 16},
      "id": 5,
      "options": {
        "cellHeight": "sm",
        "footer": {"countRows": false, "fields": "", "reducer": ["sum"], "show": false},
        "showHeader": true,
        "sortBy": [{"desc": true, "displayName": "Throughput"}]
      },
      "pluginVersion": "12.4.2",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "Prometheus"},
          "editorMode": "code",
          "expr": "label_replace(label_replace(topk(25, sum by (ip, name) (rate(ntopng_host_bytes_sent{ifname=\"LAN\"}[$__rate_interval]) + rate(ntopng_host_bytes_rcvd{ifname=\"LAN\"}[$__rate_interval])) * 8), \"vpn_status\", \"Direct\", \"ip\", \".*\"), \"vpn_status\", \"VPN\", \"ip\", \"^__VPN_IPS_REGEX__$\")",
          "format": "table",
          "instant": true,
          "range": false,
          "refId": "A"
        }
      ],
      "title": "Top 25 LAN talkers (instant)",
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {"Time": true, "__name__": true, "job": true, "instance": true},
            "indexByName": {
              "vpn_status": 0,
              "ip": 1,
              "name": 2,
              "Value": 3
            },
            "renameByName": {
              "Value": "Throughput",
              "ip": "IP",
              "name": "Name",
              "vpn_status": "Route"
            }
          }
        }
      ],
      "type": "table"
    },
    {
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "description": "Top 10 LAN hosts by current bandwidth, over time. Legend uses a `display` label computed via two chained label_replace calls: first sets display=ip for every series (the fallback), then overrides display=name whenever the name label is non-empty. Same resolution behaviour as the table above — hosts that ntopng can't resolve show as IP-only, the rest show by hostname. Because topk re-evaluates at each time-slice, the set of series can shift as traffic patterns change.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "line",
            "fillOpacity": 10,
            "gradientMode": "none",
            "hideFrom": {"legend": false, "tooltip": false, "viz": false},
            "insertNulls": false,
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "pointSize": 5,
            "scaleDistribution": {"type": "linear"},
            "showPoints": "never",
            "spanNulls": false,
            "stacking": {"group": "A", "mode": "none"},
            "thresholdsStyle": {"mode": "off"}
          },
          "mappings": [],
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}]},
          "unit": "bps"
        },
        "overrides": []
      },
      "gridPos": {"h": 10, "w": 24, "x": 0, "y": 28},
      "id": 6,
      "options": {
        "legend": {"calcs": ["mean", "max"], "displayMode": "table", "placement": "right", "showLegend": true},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "pluginVersion": "12.4.2",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "Prometheus"},
          "editorMode": "code",
          "expr": "topk(10, sum by (ip, norm_name) (label_replace(rate(ntopng_host_bytes_sent{ifname=\"LAN\", name!=\"\"}[$__rate_interval]) + rate(ntopng_host_bytes_rcvd{ifname=\"LAN\", name!=\"\"}[$__rate_interval]), \"norm_name\", \"$1\", \"name\", \"^([^.]+).*\") * 8))",
          "legendFormat": "{{norm_name}}",
          "range": true,
          "refId": "A"
        },
        {
          "datasource": {"type": "prometheus", "uid": "Prometheus"},
          "editorMode": "code",
          "expr": "topk(10, sum by (ip) (rate(ntopng_host_bytes_sent{ifname=\"LAN\"}[$__rate_interval]) + rate(ntopng_host_bytes_rcvd{ifname=\"LAN\"}[$__rate_interval])) * 8) unless on(ip) (max by (ip) (ntopng_host_bytes_rcvd{ifname=\"LAN\", name!=\"\"}))",
          "legendFormat": "{{ip}}",
          "range": true,
          "refId": "B"
        }
      ],
      "title": "LAN client bandwidth over time (top 10)",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 38},
      "id": 12,
      "panels": [],
      "title": "Upload / Download split",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "description": "Top LAN hosts by upload (positive axis) and download (negative axis). Splits the Rx/Tx directions that the combined chart above aggregates. Clients that are pulling a lot show up below the zero line; clients uploading or syncing outbound show above. Names normalized the same way as the panels above — hosts without names appear by IP. Mirrored axis makes it easy to spot download-heavy vs upload-heavy clients at a glance.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "axisCenteredZero": true,
            "axisColorMode": "text",
            "axisLabel": "",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "line",
            "fillOpacity": 20,
            "gradientMode": "none",
            "hideFrom": {"legend": false, "tooltip": false, "viz": false},
            "insertNulls": false,
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "pointSize": 5,
            "scaleDistribution": {"type": "linear"},
            "showPoints": "never",
            "spanNulls": false,
            "stacking": {"group": "A", "mode": "none"},
            "thresholdsStyle": {"mode": "off"}
          },
          "mappings": [],
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}]},
          "unit": "bps"
        },
        "overrides": []
      },
      "gridPos": {"h": 10, "w": 24, "x": 0, "y": 39},
      "id": 7,
      "options": {
        "legend": {"calcs": ["mean", "max"], "displayMode": "table", "placement": "right", "showLegend": true},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "pluginVersion": "12.4.2",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "Prometheus"},
          "editorMode": "code",
          "expr": "topk(8, sum by (ip, norm_name) (label_replace(rate(ntopng_host_bytes_sent{ifname=\"LAN\", name!=\"\"}[$__rate_interval]), \"norm_name\", \"$1\", \"name\", \"^([^.]+).*\") * 8))",
          "legendFormat": "{{norm_name}} ↑ up",
          "range": true,
          "refId": "A"
        },
        {
          "datasource": {"type": "prometheus", "uid": "Prometheus"},
          "editorMode": "code",
          "expr": "-1 * topk(8, sum by (ip, norm_name) (label_replace(rate(ntopng_host_bytes_rcvd{ifname=\"LAN\", name!=\"\"}[$__rate_interval]), \"norm_name\", \"$1\", \"name\", \"^([^.]+).*\") * 8))",
          "legendFormat": "{{norm_name}} ↓ down",
          "range": true,
          "refId": "B"
        }
      ],
      "title": "Top LAN clients — upload (↑) vs download (↓)",
      "type": "timeseries"
    }
  ],
